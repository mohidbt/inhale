# Database (Docker local dev default)
DATABASE_URL=postgres://inhale:inhale_dev@localhost:5432/inhale

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=generate-a-random-secret-here

# AES-256-GCM key for stored API keys — must be exactly 64 hex chars
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=generate-64-hex-chars-here

# Optional: directory for uploaded PDFs (default: uploads/)
# UPLOAD_DIR=uploads/
